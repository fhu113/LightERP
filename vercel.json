{
  "version": 2,
  "builds": [
    {
      "src": "packages/backend",
      "use": "@vercel/node"
    },
    {
      "src": "packages/frontend",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "packages/backend"
    },
    {
      "src": "/(.*)",
      "dest": "packages/frontend/dist/$1"
    }
  ]
}
