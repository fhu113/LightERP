{
  "name": "light-erp",
  "version": "1.0.0",
  "description": "轻量级ERP系统",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev -w packages/backend",
    "dev:frontend": "npm run dev -w packages/frontend",
    "build": "npm run build -w packages/backend && npm run build -w packages/frontend",
    "lint": "npm run lint -w packages/backend && npm run lint -w packages/frontend",
    "test": "npm run test -w packages/backend && npm run test -w packages/frontend",
    "prepare": "husky install",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.7"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "erp",
    "accounting",
    "inventory",
    "sales",
    "purchase"
  ],
  "author": "LightERP Team",
  "license": "MIT"
}