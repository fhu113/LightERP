{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS_V1",
    "buildCommand": "cd packages/backend && npm install && npx prisma generate && npm run build",
    "installCommand": "cd packages/backend && npm install",
    "root": "packages/backend"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "cd packages/backend && node dist/server.js"
  }
}
